# URL de l’API Laravel (sans slash final). Redémarre `npm run dev` après changement.
#
# php artisan serve :
# VITE_API_URL=http://127.0.0.1:8000/api
#
# XAMPP (ex. dépôt dans htdocs/CTF/CTF_Manager) :
# VITE_API_URL=http://localhost/CTF/CTF_Manager/public/api
VITE_API_URL=http://127.0.0.1:8000/api
